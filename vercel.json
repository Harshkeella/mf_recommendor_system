{
  "services": {
    "mf-recommendor-system": {
      "root": ".",
      "framework": "fastapi",
      "entrypoint": "app/api.py"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "mf-recommendor-system"
      }
    }
  ]
}
